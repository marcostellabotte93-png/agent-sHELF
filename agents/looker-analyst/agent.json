{
  "id": "looker-analyst",
  "name": "Looker Analyst",
  "version": "2.0.0",
  "category": "analytics",
  "description": "Analisi dati su Looker con focus su metriche business",
  "author": "team-it",
  "format": "custom-agent",
  "skills": {
    "core": ["agent.md"],
    "extended": [
      "skills/looker-usage.md",
      "skills/metrics-guide.md"
    ]
  },
  "mcp_servers": [
    {
      "name": "looker-docker",
      "type": "stdio",
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "LOOKER_BASE_URL",
        "-e", "LOOKER_CLIENT_ID",
        "-e", "LOOKER_CLIENT_SECRET",
        "-e", "LOOKER_VERIFY_SSL",
        "looker-mcp-toolbox"
      ],
      "env_required": ["LOOKER_CLIENT_ID", "LOOKER_CLIENT_SECRET"],
      "env_optional": {
        "LOOKER_BASE_URL": "https://jakala.cloud.looker.com/",
        "LOOKER_VERIFY_SSL": "true"
      }
    }
  ]
}
